# LLM 配置（阿里云百炼 DashScope OpenAI 兼容接口）
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
LLM_PROVIDER=dashscope

# 数据库配置
# DB_USE_SQLITE=true  时使用 SQLite（默认，无需 PostgreSQL）
# DB_USE_SQLITE=false 时使用 PostgreSQL + pgvector（启用向量检索）
DB_USE_SQLITE=true
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ci_agent

# Embedding 配置（Hybrid RAG 向量检索）
# EMBEDDING_API_KEY 留空时自动复用 LLM_API_KEY
# 模型：text-embedding-v4（Qwen3-Embedding 系列，1024 维，支持 MRL）
# 维度：1024（默认），可降至 512/256/128/64 节省存储
# 批量：v4 单次最多 10 条
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10

# 搜索配置（可选，用于在线检索竞品信息）
SEARCH_API_KEY=
SEARCH_PROVIDER=serpapi
SEARCH_MAX_RESULTS=5

# ============ 认证配置 (AuthConfig) ============
# JWT 密钥：生产环境务必修改为强随机字符串（建议 >= 32 字符）
AUTH_JWT_SECRET=change-me-in-production-please-use-a-strong-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_API_KEY_PREFIX=ci_
AUTH_API_KEY_LENGTH=32
# 认证禁用开关（true 时跳过认证，仅用于本地开发）
AUTH_DISABLED=false
# 默认管理员账号（首次启动时自动创建）
AUTH_DEFAULT_ADMIN_USERNAME=admin
AUTH_DEFAULT_ADMIN_PASSWORD=change-me-immediately
AUTH_DEFAULT_TENANT_ID=default

# ============ 速率限制 (RateLimitConfig) ============
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_TASK_CREATE=10/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_AUTH=10/minute

# ============ CORS 跨域配置 ============
# 生产环境：逗号分隔的允许来源列表
# 开发环境：自动允许 localhost:5173/4173，无需设置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============ 环境标识 ============
# development: 启用开发模式 CORS、详细日志
# production: 启用生产模式 CORS（需配置 CORS_ALLOWED_ORIGINS）
ENVIRONMENT=development
